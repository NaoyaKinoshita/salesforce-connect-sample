# Salesforce 接続情報 (OAuth 2.0 JWT Bearer Flow)
# このファイルを .env にコピーして実際の値を設定してください
# .env と秘密鍵ファイルは .gitignore に追加し、絶対にリポジトリにコミットしないでください

# Connected App の Consumer Key
SF_CLIENT_ID=your_connected_app_consumer_key

# Salesforce ログインユーザー名（メールアドレス）
SF_USERNAME=your-email@example.com

# 秘密鍵ファイルのパス（PEM形式）
SF_PRIVATE_KEY_FILE=./certs/server.key

# 本番環境: login（デフォルト）/ サンドボックス環境: test
SF_DOMAIN=login
